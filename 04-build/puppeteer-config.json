{
  "executablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
  "timeout": 60000,
  "args": [
    "--no-sandbox",
    "--disable-setuid-sandbox",
    "--disable-dev-shm-usage",
    "--disable-gpu",
    "--disable-features=site-per-process",
    "--user-data-dir=/tmp/mmdc-profile"
  ]
}
